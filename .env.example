NODE_ENV=production
PORT=3000

# Core runtime
DATABASE_URL=mysql://user:password@host:3306/foncier225
JWT_SECRET=replace-with-a-long-random-secret
VITE_APP_ID=foncier225-pilot
OAUTH_SERVER_URL=https://oauth.example.com
VITE_OAUTH_PORTAL_URL=https://oauth.example.com

# Bootstrap / ownership
OWNER_OPEN_ID=owner-open-id-for-admin-bootstrap

# Feature flags
CREDIT_WORKFLOW_ENABLED=true
DOCUMENT_GENERATION_ENABLED=true
BANK_PORTAL_ENABLED=true

# Storage and built-in proxy services
BUILT_IN_FORGE_API_URL=https://forge.example.com/
BUILT_IN_FORGE_API_KEY=replace-with-forge-api-key

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
